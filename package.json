{
  "name": "codex",
  "packageManager": "npm@11.6.2",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=docs",
    "build": "turbo run build",
    "start": "npm run start --workspace=docs",
    "format": "prettier --write .",
    "cleanup": "rm -rf package-lock.json && find . \\( -type d \\( -name node_modules -o -name .turbo -o -name dist -o -name storybook-static \\) -prune -exec rm -rf {} + \\) -o \\( -type f -name '*.tsbuildinfo' -delete \\)",
    "fresh": "npm run cleanup && npm install"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.0.1",
    "tsup": "^8.5.1",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^3.9.1"
  },
  "dependencies": {
    "@svgr/cli": "^8.1.0"
  }
}
