{
  "name": "@opus2-platform/codex",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev:bootstrap": "npm run build:ts && npm run build:css",
    "dev:css": "nodemon --watch src/styles --ext css --exec \"npm run build:css\"",
    "dev:watch": "concurrently \"tsc --watch -p tsconfig.build.json\" \"tsc-alias --watch -p tsconfig.build.json\" \"npm run dev:css\"",
    "dev": "npm run dev:bootstrap && npm run dev:watch",
    "build:ts": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:css": "postcss src/styles/index.css -o dist/styles.css",
    "build": "npm run build:ts && npm run build:css"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "dependencies": {
    "@opus2-platform/icons": "*",
    "@tiptap/extension-color": "^2.27.2",
    "@tiptap/extension-font-family": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-text-style": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "embla-carousel-react": "^8.5.2",
    "input-otp": "^1.4.2",
    "motion": "^12.36.0",
    "qr-code-styling": "^1.9.2",
    "react-aria": "^3.46.0",
    "react-aria-components": "^1.16.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "tsc-alias": "^1.8.16"
  }
}
