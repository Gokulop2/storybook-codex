{
  "name": "@opus2-platform/codex",
  "version": "0.1.0",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.d.ts"
    },
    "./dist/styles.css": "./dist/styles.css"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "tsup --watch & npm run css:build --watch",
    "prebuild": "rm -rf dist",
    "types": "tsc --emitDeclarationOnly --declaration --project tsconfig.json",
    "build": "tsup && npm run types && npm run postbuild",
    "postbuild": "npm run css:build && cp package.json dist/",
    "css:build": "postcss src/styles/index.css -o dist/styles.css"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.0",
    "@opus2-platform/icons": "*",
    "@react-aria/utils": "^3.33.1",
    "@react-stately/utils": "^3.11.0",
    "@tiptap/core": "^3.21.0",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-text-align": "^3.21.0",
    "@tiptap/extension-text-style": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@untitledui/file-icons": "^0.0.9",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "motion": "^12.38.0",
    "qr-code-styling": "^1.9.2",
    "react-aria": "^3.47.0",
    "react-aria-components": "^1.16.0",
    "react-hotkeys-hook": "^5.2.4",
    "recharts": "^3.8.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "hast-util-to-jsx-runtime": "^2.3.6"
  }
}
